# Choose ONE provider (Groq is easiest for local dev):
#
# Option A — Groq (https://console.groq.com/keys) — key starts with gsk_
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
#
# Option B — xAI Grok (https://console.x.ai/) — key starts with xai-
# LLM_PROVIDER=xai
# GROK_API_KEY=your_xai_api_key_here
# GROK_MODEL=grok-2-latest
